generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ContentStatus {
  ACTIVE
  INACTIVE
}

enum BannerSourceType {
  BUILTIN
  CUSTOM
}

enum BannerDisplayMode {
  RANDOM
  ROTATE
}

enum SalesReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReminderStatus {
  UNREAD
  READ
}

enum ReminderTemplate {
  TARGET_GAP
  MISSING_SUBMISSION
  FOLLOW_UP
  CUSTOM
}

model User {
  id                  String           @id @default(cuid())
  username            String           @unique
  passwordHash        String
  name                String
  phone               String?
  role                Role
  status              UserStatus       @default(ACTIVE)
  salesRecords        SalesRecord[]
  commissionRules     CommissionRule[]
  dailyTargets        DailyTarget[]
  adjustedDailyTargets DailyTarget[]   @relation("DailyTargetAdjustedBy")
  receivedReminders   MemberReminder[] @relation("MemberReminderRecipient")
  sentReminders       MemberReminder[] @relation("MemberReminderSender")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("users")
}

model SalesRecord {
  id              String            @id @default(cuid())
  userId          String
  saleDate        DateTime          @db.Date
  count40         Int               @default(0)
  count60         Int               @default(0)
  remark          String?
  lastSubmittedAt DateTime?
  reviewStatus    SalesReviewStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewNote      String?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId, saleDate])
  @@index([saleDate])
  @@index([saleDate, reviewStatus, lastSubmittedAt])
  @@index([saleDate, lastSubmittedAt])
  @@map("sales_records")
}

model CommissionRule {
  id             String   @id @default(cuid())
  userId         String
  price40        Decimal  @db.Decimal(10, 2)
  price60        Decimal  @db.Decimal(10, 2)
  effectiveStart DateTime @db.Date
  effectiveEnd   DateTime? @db.Date
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, effectiveStart, effectiveEnd])
  @@map("commission_rules")
}

model DailyTarget {
  id               String   @id @default(cuid())
  userId           String
  targetDate       DateTime @db.Date
  suggestedTotal   Int
  finalTotal       Int
  suggestionReason String
  adjustedById     String?
  adjustedAt       DateTime?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adjustedBy       User?    @relation("DailyTargetAdjustedBy", fields: [adjustedById], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, targetDate])
  @@index([targetDate])
  @@index([targetDate, userId])
  @@map("daily_targets")
}

model MemberReminder {
  id        String           @id @default(cuid())
  userId    String
  type      ReminderTemplate
  title     String
  content   String
  status    ReminderStatus   @default(UNREAD)
  sentById  String?
  sentAt    DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation("MemberReminderRecipient", fields: [userId], references: [id], onDelete: Cascade)
  sentBy    User?            @relation("MemberReminderSender", fields: [sentById], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, sentAt])
  @@index([userId, status, sentAt])
  @@map("member_reminders")
}

model BannerQuote {
  id         String           @id @default(cuid())
  content    String
  author     String?
  sourceType BannerSourceType @default(CUSTOM)
  status     ContentStatus    @default(ACTIVE)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@map("banner_quotes")
}

model BannerSettings {
  id          String            @id
  isEnabled   Boolean           @default(true)
  displayMode BannerDisplayMode @default(RANDOM)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("banner_settings")
}

model Announcement {
  id        String        @id @default(cuid())
  title     String
  content   String
  isPinned  Boolean       @default(false)
  status    ContentStatus @default(ACTIVE)
  publishAt DateTime      @default(now())
  expireAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, publishAt, expireAt, isPinned])
  @@map("announcements")
}
