# PostgreSQL connection string used by Prisma and the application.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maika?schema=public"

# Required by Auth.js for signing session tokens.
AUTH_SECRET="replace-with-a-random-long-secret"

# Set to true on Vercel and most preview environments so Auth.js trusts the host header.
AUTH_TRUST_HOST="true"
